generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  ACTIF
  INACTIF
}

enum InvoiceStatus {
  BROUILLON
  ENVOYEE
  PAYEE
  RETARD
}

enum ContractStatus {
  ACTIF
  A_RENOUVELER
  EXPIRE
}

enum ReminderStatus {
  SCHEDULED
  SENT
  FAILED
  CANCELED
}

enum ReminderChannel {
  EMAIL
  SMS
}

model User {
  id          String     @id @default(cuid())
  clerkId     String     @unique
  email       String?
  name        String?
  company     String?
  vatNumber   String?
  siren       String?
  address     String?
  iban        String?
  logoUrl     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  clients     Client[]
  invoices    Invoice[]
  contracts   Contract[]
  reminders   Reminder[]
  eventLogs   EventLog[]
}

model Client {
  id        String       @id @default(cuid())
  userId    String
  name      String
  email     String
  company   String
  city      String?
  vatNumber String?
  status    ClientStatus @default(ACTIF)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  contracts Contract[]

  @@index([userId])
}

model Invoice {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  number      String
  issueDate   DateTime      @default(now())
  dueDate     DateTime
  amountHt    Decimal       @db.Decimal(12, 2)
  taxRate     Decimal       @db.Decimal(5, 2)
  amountTax   Decimal       @db.Decimal(12, 2)
  amountTtc   Decimal       @db.Decimal(12, 2)
  status      InvoiceStatus @default(BROUILLON)
  pdfUrl      String?
  sentAt      DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reminders   Reminder[]

  @@index([userId])
  @@index([clientId])
  @@unique([userId, number])
}

model Contract {
  id              String         @id @default(cuid())
  userId          String
  clientId        String
  contractType    String?
  title           String
  content         String?
  country         String?
  language        String?
  startDate       DateTime
  endDate         DateTime
  amount          Decimal        @db.Decimal(12, 2)
  status          ContractStatus @default(ACTIF)
  signatureStatus String?
  pdfUrl          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
}

model Reminder {
  id           String          @id @default(cuid())
  userId       String
  invoiceId    String
  scheduleDate DateTime
  status       ReminderStatus  @default(SCHEDULED)
  channel      ReminderChannel @default(EMAIL)
  sentAt       DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice      Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([invoiceId])
}

model EventLog {
  id         String   @id @default(cuid())
  userId     String?
  eventType  String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
}
