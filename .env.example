# Supabase project URL (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase public anon key (Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Supabase service role key (server only, never expose in client code)
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Prisma runtime connection via Supabase pooler
DATABASE_URL="postgresql://postgres.hgpsuxdisugoirpxvvmh:YOUR_DB_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Prisma direct connection for migrations/introspection
DIRECT_URL="postgresql://postgres.hgpsuxdisugoirpxvvmh:YOUR_DB_PASSWORD@db.hgpsuxdisugoirpxvvmh.supabase.co:5432/postgres"

# Clerk auth keys (required when LOCAL_DEV_AUTH is false)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# Enable only for local development auth bypass
LOCAL_DEV_AUTH="false"
